# Copy this file to ".env" in the same folder as api.py / pipd_composite_report.py
#   copy .env.example .env
# Then set your OpenAI API key (never commit .env).
OPENAI_API_KEY=your-openai-api-key-here


OPENAI_MODEL=gpt-4o-mini
# Longer AI documentation (full doc from prompts/ai_doc_system.txt + user template)
OPENAI_DOC_MAX_TOKENS=4096
# Optional: rewrite Scenario 1 report Markdown to match reference Word (structure/tables only)
# PIPD_OPENAI_REFERENCE_LAYOUT=0
# Append AI section from USDM JSON + ground-truth CSV excerpts (excerpt-grounded prose; no metric edits)
# PIPD_OPENAI_REPORT_ENRICH=0
# OPENAI_ENRICH_MAX_TOKENS=4500
# Override path to reference .docx for OpenAI layout (no repo default; set explicitly)
# PIPD_EVAL_REFERENCE_DOCX=
# Max completion tokens for OpenAI reference layout (long reports)
# OPENAI_REF_LAYOUT_MAX_TOKENS=12000

# Optional: composite eval — percentage points subtracted from final % per hallucination
# PIPD_HALLUCINATION_DEDUCTION_SUB_PCT=0.25
# PIPD_HALLUCINATION_DEDUCTION_CAT_PCT=1.0

# Eval report layout (default: reference-style Word from Markdown)
# PIPD_EVAL_REPORT_STYLE=reference
# Optional: path to pipd_eval_config.yaml (default: eval_config/pipd_eval_config.yaml under ppid_py)
# PIPD_EVAL_CONFIG_PATH=
# USDM protocol JSON for traceability + truth verification (else auto-discover under data/)
# PIPD_USDM_JSON=
# PIPD_DATA_DIR=
# Optional: OpenAI picks USDM excerpt when lexical match is weak (requires OPENAI_API_KEY)
# PIPD_USDM_SOURCE_AI=0
# PIPD_USDM_LEXICAL_MIN=0.18
# PIPD_USDM_AI_BELOW_RATIO=0.35
# Eval report Markdown / Word table cells: 0 = minimal truncation (~250k chars/cell)
# PIPD_EVAL_REPORT_CELL_MAX=0
# Optional matplotlib figures in scenario1 report (default off: use 1 or true)
# PIPD_EVAL_REPORT_FIGURES=0
# Scenario 1 report outputs: all | json_docx (only {study}_scenario1_report.json + .docx)
# PIPD_SCENARIO1_ARTIFACTS=all
# Document pass/target: taken from YAML scoring.* when file loads; else:
# PIPD_EVAL_PASS_THRESHOLD=75
# PIPD_EVAL_TARGET_SCORE=80
# PIPD_EVAL_CONFIG_LABEL=composite+scenario1
